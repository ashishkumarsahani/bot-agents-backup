{
  "name": "dhyanapp-bot-engagement-functions",
  "version": "1.0.0",
  "description": "Cloud Functions for bot engagement (likes and comments) on posts",
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "deploy": "firebase deploy --only functions",
    "deploy:engagement": "firebase deploy --only functions:onPostCreated,functions:processComment,functions:processLike",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "@google-cloud/tasks": "^5.1.0",
    "openai": "^4.20.0"
  },
  "private": true
}
